# ─── Shop_a_Bot — environment variables reference ──────────────────────────
#
# This file is committed (no secrets, just keys + descriptions) so the
# team has ONE place to check which env vars the app needs. On Manus,
# these are configured as project secrets — copy each KEY name from
# here and set its value in the Manus secrets UI.
#
# Three tiers:
#   REQUIRED      — server refuses to start without it
#   RECOMMENDED   — feature won't work without it (logged at startup)
#   OPTIONAL      — opt-in, has a sensible default
#
# Validated at boot in server/_core/env.ts → validateRequiredEnv().

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED — server cannot start safely without these
# ═══════════════════════════════════════════════════════════════════════════

# MySQL connection string. Format:
#   mysql://user:password@host:3306/database?ssl-mode=REQUIRED
DATABASE_URL=

# JWT signing secret. On Manus this is auto-injected by the platform —
# leave it alone unless you're self-hosting. For self-hosting, generate
# a strong one with:  openssl rand -base64 48
# Server logs a warning (NOT a fatal) if length < 32.
JWT_SECRET=

# ═══════════════════════════════════════════════════════════════════════════
# RECOMMENDED — features below depend on these
# ═══════════════════════════════════════════════════════════════════════════

# ── Production CORS allowlist ──────────────────────────────────────────────
# Comma-separated list of origins allowed to hit /api/*. In production,
# this MUST be set or the server will refuse to start (no localhost fallback).
ALLOWED_ORIGINS=https://shop-a-bot.app,https://www.shop-a-bot.app

# ── Redis (BullMQ job queues) ──────────────────────────────────────────────
# Manus typically provisions this. Without it, async workflows degrade
# to inline execution.
REDIS_URL=

# ── Stripe (billing + checkout + trial gate) ───────────────────────────────
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── SendGrid (transactional + marketing email — preferred provider) ────────
# Drop SENDGRID_API_KEY to disable; the delivery layer falls back to
# Gmail OAuth per-user automatically.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@shop-a-bot.app
SENDGRID_FROM_NAME=Shop_a_Bot
# Optional: enables ECDSA signature verification on /api/webhooks/sendgrid
# Get the public key from SendGrid → Mail Settings → Event Webhook.
SENDGRID_WEBHOOK_PUBLIC_KEY=

# ── Twilio (SMS — recovery flows, transactional notifications) ─────────────
# One of TWILIO_FROM_NUMBER or TWILIO_MESSAGING_SERVICE_SID is required.
# Messaging-service is preferred for production (handles A2P, opt-out).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# ── Shopify Partner OAuth (store connection) ───────────────────────────────
SHOPIFY_PARTNER_CLIENT_ID=
SHOPIFY_PARTNER_CLIENT_SECRET=

# ── Google OAuth (Gmail + Google Ads + GA4 + sign-in) ─────────────────────
# VITE_GOOGLE_CLIENT_ID is the canonical name — the same value is embedded
# in the browser bundle (OAuth login URL) AND read server-side for the
# token exchange. GOOGLE_CLIENT_ID is accepted as a legacy alias so
# existing Manus secrets continue to work. Set at least one of the two.
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Legacy alias — only needed when migrating from GOOGLE_CLIENT_ID.
# Remove once all Manus projects have been updated to VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# ── Manus session SDK (auth) ───────────────────────────────────────────────
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=https://manus.ai
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ── LLM (Manus Forge) ──────────────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
FORGE_LLM_MODEL=gemini-2.5-flash

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL — social / e-commerce platforms (each unlocks one Connect tile)
# ═══════════════════════════════════════════════════════════════════════════

# ── Meta (Facebook + Instagram) ────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_CLIENT_ID=
META_CLIENT_SECRET=
META_BUSINESS_ID=

# ── TikTok (Social + Shop) ─────────────────────────────────────────────────
TIKTOK_APP_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Twitter / X ────────────────────────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── Pinterest ──────────────────────────────────────────────────────────────
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_ACCESS_TOKEN=

# ── Outlook / Microsoft Graph (Mail + Calendar) ────────────────────────────
# App registered at portal.azure.com → Azure AD → App registrations.
# After creating the app, go to "API permissions" and add Microsoft Graph
# delegated permissions: Mail.Read, Mail.Send, Calendars.Read,
# Calendars.ReadWrite, User.Read, offline_access. Then click
# "Grant admin consent". The redirect URI must be your app's
# /api/social/oauth/callback endpoint.
# Leave AZURE_TENANT_ID=common to support both work and personal accounts.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common

# ── Slack ──────────────────────────────────────────────────────────────────
# Create at api.slack.com/apps → From scratch. Add bot scopes:
# chat:write, channels:read, channels:history, reactions:read,
# users:read, files:read, files:write. Add the redirect URL
# /api/social/oauth/callback under OAuth & Permissions.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_VERIFICATION_TOKEN=

# ── YouTube ────────────────────────────────────────────────────────────────
# YouTube uses the same Google OAuth client as Gmail (GOOGLE_CLIENT_ID /
# _SECRET). After connecting, the user grants the youtube.upload +
# youtube.readonly scopes. The optional API key below unlocks read-only
# analytics without requiring a user token.
YOUTUBE_API_KEY=

# ── Etsy ───────────────────────────────────────────────────────────────────
ETSY_API_KEY=
ETSY_SHARED_SECRET=

# ── eBay ───────────────────────────────────────────────────────────────────
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=

# ── Amazon SP-API ──────────────────────────────────────────────────────────
AMAZON_SP_CLIENT_ID=
AMAZON_SP_CLIENT_SECRET=

# ── Runtime ────────────────────────────────────────────────────────────────
# All optional; sane defaults documented next to each.

# Server bind port (default: 3000). Manus auto-injects in hosted deploys.
PORT=

# Logger verbosity: trace | debug | info | warn | error (default: info)
LOG_LEVEL=

# Origin used when generating absolute URLs in emails + OAuth redirects.
# Falls back to the request's protocol+host. Set when behind a proxy
# that rewrites Host. Manus reverse proxy doesn't require this.
PUBLIC_APP_ORIGIN=

# 32-byte base64 key used to encrypt platform credential tokens at rest
# (platformCredentials.accessToken, socialAccounts.refreshToken, etc).
# When unset, secrets are stored plaintext — fine for self-hosted dev,
# but production deploys (including Manus) MUST set this.
# Generate with: `openssl rand -base64 32`
TOKEN_ENCRYPTION_KEY=

# ── Claude direct path (opt-in) ────────────────────────────────────────────
# When set, workflows tagged with `useClaudeDirect: true` route through the
# official Anthropic SDK to unlock prompt caching, adaptive thinking, and
# the `effort` parameter (low/medium/high/xhigh/max). When unset, every
# call falls back to the Forge proxy — no breaking change.
# Get a key from console.anthropic.com.
ANTHROPIC_API_KEY=
# Override the default model. claude-opus-4-7 is the recommended default.
# Other options: claude-sonnet-4-6 (balanced), claude-haiku-4-5 (fast/cheap).
ANTHROPIC_MODEL=

# ── Research / web-data tools (optional) ───────────────────────────────────
# Firecrawl turns any URL into LLM-ready markdown. When set, the
# Builder Bot's `scout_url` agent tool uses real scraped content;
# when unset, the tool gracefully reports "service unavailable" and
# the agent reasons from its other (synthetic) tool outputs instead.
# Get a key from https://firecrawl.dev (free tier: 500 scrapes/month).
FIRECRAWL_API_KEY=

# Tavily turns a query into ranked URLs + a synthesized one-paragraph
# answer. Pairs with Firecrawl: Tavily for *discovery* (search),
# Firecrawl for *deep-scrape* (one URL → markdown). When set, the
# `web_search` agent tool — wired into ALL three bot toolsets
# (architect/merchant/social) — uses real search; when unset, it
# reports "service unavailable" gracefully so the agent reasons from
# its other tools. Pay-as-you-go plan recommended for production.
# Get a key from https://tavily.com.
TAVILY_API_KEY=

# ── Misc ───────────────────────────────────────────────────────────────────
BEASTBOTS_PAGE_ID=
NODE_ENV=production
